# Required env vars for Arcan's paid ads launch
# Add these in Coolify → Arcan app → Environment Variables
# Group A is required for launch. Group B is optional / needed for advanced features.
#
# This file is the SINGLE SOURCE OF TRUTH. If a doc says to set X, the value is here.
# After: restart Arcan's app container.

# ============================================================================
# GROUP A — Required for the 6 paid ad campaigns to function
# ============================================================================

# Meta Lead Ads webhook receiver.
# 1. Open Meta Business Suite → Lead Form → CRM Webhook URL
# 2. Set URL to: https://arcanpainting.ca/api/lead-webhook/meta
# 3. Generate a verify token, paste the SAME value here:
META_LEAD_VERIFY_TOKEN=replace-me-with-random-string
# Meta Conversions API (server-side attribution)
# 1. Events Manager → Pixels → [Your Pixel] → Settings → Conversions API
# 2. Click "Generate access token" (long-lived system-user token)
META_CAPI_TOKEN=replace-me-with-meta-system-user-token
# Meta Pixel ID (server-side)
# 1. Events Manager → Pixels → copy the numeric Pixel ID
META_PIXEL_ID=replace-me-with-numeric-pixel-id

# Meta Pixel ID (client-side, exposed via NEXT_PUBLIC_)
# Must be the SAME value as META_PIXEL_ID above.
# Set in Part 4 of SETUP.md (the <head> snippet uses this var).
NEXT_PUBLIC_META_PIXEL_ID=replace-me-with-numeric-pixel-id

# Toggle the CAPI helper on/off. true = active, false = no-op (safe default).
META_CAPI_ENABLED=true

# Test mode: true = events go to Meta's Test Events tool, false = production.
# CRITICAL: Set to true during initial setup (Day 3), set to false BEFORE
# publishing Meta campaigns (Day 5). Otherwise all CAPI attribution goes to
# Test Events instead of Live Events — leads flow but Meta sees zero conversions.
# Verify in Meta Events Manager → Live Events (not Test Events) that Lead events arrive.
META_CAPI_TEST=true

# Production URL. Used by:
# - meta-capi.js for event_source_url
# - email-workflows for template link generation
# - the Meta webhook for internal fetch baseURL
# In Coolify, set this to https://arcanpainting.ca
APP_URL=https://arcanpainting.ca

# ============================================================================
# GROUP B — Optional / needed for specific features
# ============================================================================

# Optional: which Meta page the webhook receives from. Webhook accepts any form
# on any connected page, so this is just for logging.
META_LEAD_PAGE_ID=

# Optional: Lead Form ID for logging only.
META_LEAD_FORM_ID=

# Optional: which Meta Graph API version to use. Default v18.0.
META_API_VERSION=v18.0

# Optional: test event code shown in Meta Events Manager → Test Events.
# Only used when META_CAPI_TEST=true.
META_CAPI_TEST_CODE=TEST12345

# Required for cron-triggered endpoints (delayed-emails worker,
# dashboard-summary daily push). Generate a random string.
# Same value used for: x-cron-secret header on /api/delayed-emails
# and /api/ads/dashboard-summary.
CRON_SECRET=replac...g
